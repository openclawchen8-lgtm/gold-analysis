# ============================================
# Gold Analysis Core - API Keys Configuration
# ============================================
# Copy this file to .env and fill in your API keys
# NEVER commit .env to version control

# Alpha Vantage (Free: 5 calls/min, 500 calls/day)
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Finnhub (Free tier available)
# https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# FRED - Federal Reserve Economic Data (Free)
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# ============================================
# Optional: Alternative Data Sources
# ============================================

# Gold API (Specialized for gold prices)
# https://www.goldapi.io/
# GOLD_API_KEY=your_gold_api_key_here

# Exchange Rate API (Currency conversion)
# https://www.exchangerate-api.com/
# EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here
